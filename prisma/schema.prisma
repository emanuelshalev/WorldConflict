// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Player {
  id           String   @id @default(uuid())
  name         String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model SaveGame {
  id          String   @id @default(uuid())
  name        String
  worldState  String   // JSON serialized WorldState
  playerCountry String
  playerId    String?  // owning player account
  leaderName  String?  // how the player is addressed in this game
  seed        Int
  turn        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TurnLog {
  id         String   @id @default(uuid())
  saveGameId String
  turn       Int
  events     String   // JSON serialized events
  actions    String   // JSON serialized actions
  createdAt  DateTime @default(now())
}
